# ============================================
# !doneyet — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# The app works in OFFLINE MODE without these — all data saved locally.
# Setting up Firebase enables cloud sync, auth, and multiplayer features.

# ── Firebase Config ──
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project (name: "doneyet" or "codegrid")
# 3. Go to Project Settings → General → Your apps → Add web app
# 4. Copy the config values here:
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Auth Setup ──
# After creating the project:
# 1. Go to Authentication → Sign-in method
# 2. Enable "Google" provider (add your email as support email)
# 3. Enable "GitHub" provider:
#    - Go to https://github.com/settings/developers
#    - Create new OAuth App
#    - Homepage URL: http://localhost:3000
#    - Callback URL: (copy from Firebase Console)
#    - Paste Client ID + Secret into Firebase
# 4. Enable "Anonymous" provider (for guest login)
# 5. Go to Authentication → Settings → Authorized domains
#    - Add: localhost

# ── Gemini AI (optional — for "Who Cares" chatbot) ──
# Get a key from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
